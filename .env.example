# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# VK
VK_GROUP_TOKEN=your_vk_group_token
VK_GROUP_ID=your_vk_group_id
VK_API_VERSION=5.120

# Google Sheets
GOOGLE_SHEETS_URL=https://docs.google.com/spreadsheets/d/your_spreadsheet_id
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/google-service-account.json

# Admin commands suffix (e.g. refresh_GS_<ADMIN_SECRET>)
ADMIN_SECRET=change_me

# Telegram channel (optional)
TELEGRAM_CHANNEL_USERNAME=@your_channel
TELEGRAM_CHANNEL_INVITE_URL=https://t.me/+your_invite_hash
TELEGRAM_CHANNEL_PUBLIC_URL=https://t.me/your_channel
